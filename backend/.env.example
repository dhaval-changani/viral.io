# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# ─── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/youtube_automation

# ─── OpenAI (GPT-4o via Vercel AI SDK) ───────────────────
OPENAI_API_KEY=

# ─── ElevenLabs (TTS) ────────────────────────────────────
ELEVENLABS_API_KEY=
# Default voice ID to use for narration
ELEVENLABS_VOICE_ID=

# ─── Runway Gen-3 Alpha Turbo (B-roll generation) ────────
RUNWAY_API_KEY=

# ─── Epidemic Sound (background music) ───────────────────
EPIDEMIC_SOUND_API_KEY=

# ─── YouTube Data API v3 (Google Cloud Console) ──────────
YOUTUBE_API_KEY=
# OAuth2 credentials for uploading videos
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
